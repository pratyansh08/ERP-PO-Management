### Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/po_db

### Google OAuth (create credentials in Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Must match the authorized redirect URI configured in Google Console
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback?redirect_to=http://127.0.0.1:5500/dashboard.html

### JWT
JWT_SECRET_KEY=change_this_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

### OpenAI (optional)
# If not provided, the backend uses a mock fallback description.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
